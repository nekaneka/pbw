# ============================================================
# Pflegeberatung Wien – Environment variables
# Copy this file to .env.local and fill in real values.
# Without any values the app runs with a local JSON file store
# (./.data/appointments.json) and logs e-mails to the console.
# ============================================================

# --- Public site URL (used for canonical URL, sitemap, robots, OG tags) ---
# TODO: replace with the real domain once registered
NEXT_PUBLIC_SITE_URL=https://www.pflegeberatung-wien.at

# --- Admin login (/admin) ---
# Password for the provider's admin area. Minimum 8 characters.
# Without this, the admin area cannot be used at all.
ADMIN_PASSWORD=bitte-aendern-123

# --- Supabase (Postgres database) ---
# Create a project at https://supabase.com, run supabase/schema.sql,
# then fill these in. Both must be set to activate the Supabase store.
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never expose to the client

# --- Resend (transactional e-mails) ---
# Create an API key at https://resend.com. Without a key, e-mails are
# skipped and logged to the server console instead.
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Sender address (must be a verified domain in Resend)
# EMAIL_FROM="Pflegeberatung Wien <termine@pflegeberatung-wien.at>"

# Provider address that receives booking notifications
# TODO: replace placeholder e-mail
# PROVIDER_EMAIL=kontakt@pflegeberatung-wien.at
